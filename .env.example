# Copy to .env and adjust. Bun auto-loads .env for `bun run`.

# Postgres credentials (used by docker-compose and the API).
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=recommendation_engine
POSTGRES_PORT=5432

# API port.
PORT=3000

# When set, the API uses PostgreSQL instead of the in-memory store.
# Leave unset to run fully in memory.
DATABASE_URL=postgres://app:app@localhost:5432/recommendation_engine

# Optional connection pool size (defaults to 10).
# DATABASE_POOL_MAX=10

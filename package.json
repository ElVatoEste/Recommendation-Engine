{
  "name": "recommendation-engine",
  "version": "0.1.0",
  "description": "A modular recommendation engine built from first principles with event-driven ingestion, product statistics, and explainable ranking layers.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/ElVatoEste/Recommendation-Engine.git"
  },
  "bugs": {
    "url": "https://github.com/ElVatoEste/Recommendation-Engine/issues"
  },
  "homepage": "https://github.com/ElVatoEste/Recommendation-Engine#readme",
  "keywords": [
    "recommendation-engine",
    "recommender-system",
    "typescript",
    "bun",
    "event-driven",
    "ranking",
    "graph",
    "machine-learning"
  ],
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "bun run ./apps/api/src/server.ts",
    "dev:web": "bun --filter web run dev",
    "cli": "bun run ./apps/cli/src/index.ts",
    "playground": "bun run ./apps/playground/src/demo.ts",
    "check": "tsc --noEmit",
    "check:web": "bun --filter web run check",
    "build:web": "bun --filter web run build",
    "test": "bun test",
    "test:pg": "RUN_PG_TESTS=1 bun test packages/storage/src/postgres-event-store.integration.test.ts",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "stack:up": "docker compose --profile api up -d --build",
    "stack:down": "docker compose --profile api down"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "cli-table3": "^0.6.5",
    "commander": "^15.0.0",
    "ora": "^9.4.1",
    "pg": "^8.22.0",
    "picocolors": "^1.1.1"
  }
}
